# ==========================================
# Antigravity 自動投稿・スクレイピングシステム 設定
# ==========================================

# 1. Gemini API 設定
# 取得元: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# 2. 投稿モード設定
# 'dryrun' : Xに投稿せずコンソールに出力してテスト（初期値）
# 'api'    : X API (公式) を使用して投稿
# 'browser': Playwright によるブラウザ自動化を使用して投稿
PUBLISH_MODE=dryrun

# 3. X (Twitter) API 資格情報 (PUBLISH_MODE=api の場合に必要)
# 取得元: https://console.x.com/
X_CONSUMER_KEY=YOUR_X_CONSUMER_KEY
X_CONSUMER_SECRET=YOUR_X_CONSUMER_SECRET
X_ACCESS_TOKEN=YOUR_X_ACCESS_TOKEN
X_ACCESS_TOKEN_SECRET=YOUR_X_ACCESS_TOKEN_SECRET

# 4. X ブラウザオートメーション設定 (PUBLISH_MODE=browser の場合に必要)
# 初回のログインセッション保存先クッキーファイル
X_COOKIE_PATH=auth_cookies.json
